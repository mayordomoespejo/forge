{
    "name": "miguelmayordomoespejo/forge",
    "description": "AI-powered content analyzer and chat using Azure AI and Microsoft Foundry",
    "type": "project",
    "require": {
        "php": ">=8.3",
        "guzzlehttp/guzzle": "^7.0",
        "vlucas/phpdotenv": "^5.0",
        "dompdf/dompdf": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Forge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Forge\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
